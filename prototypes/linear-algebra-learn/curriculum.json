      "resources": [
        {"title": "MIT 18.06 Lec 5-7 Vector Spaces", "url": "https://ocw.mit.edu/courses/18-06-linear-algebra-spring-2010/", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "给定矩阵 A，求出 C(A) 和 N(A) 的一组生成向量", "assessable": true}
