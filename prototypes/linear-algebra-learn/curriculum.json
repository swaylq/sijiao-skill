{
  "skill": "linear-algebra",
  "modules": [
    {
      "id": "vectors",
      "title": "向量与向量运算",
      "dreyfus_stage": "novice",
      "prereqs": [],
      "objectives": [
        {"text": "把向量同时理解成『一列数』和『空间中的箭头』", "bloom": "understand"},
        {"text": "手算向量加法、数乘，并画出几何意义", "bloom": "apply"}
      ],
      "resources": [
        {"title": "3Blue1Brown · Essence of LA ch.1-2", "url": "https://www.3blue1brown.com/topics/linear-algebra", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "给定 5 组向量，手算 2u-3v 并在坐标纸画出，再用 numpy 验证", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "matrices-basics",
      "title": "矩阵入门：矩阵-向量乘法是线性组合",
      "dreyfus_stage": "novice",
      "prereqs": ["vectors"],
      "objectives": [
        {"text": "解释 Ax 是 A 的列向量按 x 加权的线性组合", "bloom": "understand"}
      ],
      "resources": [
        {"title": "MIT 18.06 Unit 1 (Strang)", "url": "https://ocw.mit.edu/courses/18-06-linear-algebra-spring-2010/", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "对 3 个 Ax，分别用『行点积』和『列线性组合』两种方式各算一遍，结果一致", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "matrix-operations",
      "title": "矩阵运算：乘法、转置、逆",
      "dreyfus_stage": "novice",
      "prereqs": ["matrices-basics"],
      "objectives": [
        {"text": "手算矩阵乘法，理解它是复合线性变换", "bloom": "apply"},
        {"text": "说清逆矩阵在解什么问题", "bloom": "understand"}
      ],
      "resources": [
        {"title": "3Blue1Brown · 矩阵乘法/复合", "url": "https://www.3blue1brown.com/topics/linear-algebra", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "手算两个 2x2 矩阵乘积；求一个 2x2 的逆并验证 A·A⁻¹=I", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "linear-systems",
      "title": "线性方程组与高斯消元",
      "dreyfus_stage": "novice",
      "prereqs": ["matrix-operations"],
      "objectives": [
        {"text": "用高斯消元把 Ax=b 化成行阶梯形求解", "bloom": "apply"},
        {"text": "判断方程组解的三种情况（唯一/无穷/无解）", "bloom": "analyze"}
      ],
      "resources": [
        {"title": "MIT 18.06 Lec 2-3 Elimination", "url": "https://ocw.mit.edu/courses/18-06-linear-algebra-spring-2010/", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "手动消元解一个 3x3 系统；构造一个无解和一个无穷解的例子各一个", "assessable": true}
      ],
      "milestone": {"project": "手解一个 3 元方程组并解释解的结构", "competence_check": "能独立消元到行阶梯形并判断解的情况"},
      "honest_limit": null
    },
