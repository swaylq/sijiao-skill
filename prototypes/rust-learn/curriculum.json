{
  "skill": "rust",
  "modules": [
    {
      "id": "setup-toolchain",
      "title": "工具链与第一个程序",
      "dreyfus_stage": "novice",
      "prereqs": [],
      "objectives": [
        {"text": "用 rustup 装好工具链，能 cargo new / run / build", "bloom": "apply"},
        {"text": "说清 cargo 是包管理器 + 构建器 + 测试器", "bloom": "understand"}
      ],
      "resources": [
        {"title": "TRPL ch.1 Getting Started", "url": "https://doc.rust-lang.org/book/ch01-00-getting-started.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "cargo new hello，改 main 打印一句话，cargo run 跑通；再 cargo build --release 看 target 目录变化", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "syntax-basics",
      "title": "基础语法：变量、类型、函数、控制流",
      "dreyfus_stage": "novice",
      "prereqs": ["setup-toolchain"],
      "objectives": [
        {"text": "区分 let / let mut / const，说清不可变默认", "bloom": "understand"},
        {"text": "写带参数和返回值的函数 + if / loop / while / for", "bloom": "apply"}
      ],
      "resources": [
        {"title": "TRPL ch.3 Common Programming Concepts", "url": "https://doc.rust-lang.org/book/ch03-00-common-programming-concepts.html", "type": "primary"},
        {"title": "Rustlings: variables / functions / if", "url": "https://github.com/rust-lang/rustlings", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "做 Rustlings 的 variables + functions + if 三组，全部编译通过", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "ownership",
      "title": "所有权与 move 语义",
      "dreyfus_stage": "novice",
      "prereqs": ["syntax-basics"],
      "objectives": [
        {"text": "解释 move 后原变量失效、为何这样设计（无 GC 的内存安全）", "bloom": "understand"},
        {"text": "判断一段代码哪里发生 move、哪里需要 clone", "bloom": "analyze"}
      ],
      "resources": [
        {"title": "TRPL ch.4.1 What is Ownership", "url": "https://doc.rust-lang.org/book/ch04-01-what-is-ownership.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "做 Rustlings move_semantics 全组；对每个修复说出『为什么这里 move 了』", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "borrowing-references",
      "title": "借用与引用",
      "dreyfus_stage": "novice",
      "prereqs": ["ownership"],
      "objectives": [
        {"text": "复述借用三原则（任意多个 & 或 唯一一个 &mut，不可同时）", "bloom": "remember"},
        {"text": "把一个 move-报错的函数改成借用，编译通过", "bloom": "apply"}
      ],
      "resources": [
        {"title": "TRPL ch.4.2 References and Borrowing", "url": "https://doc.rust-lang.org/book/ch04-02-references-and-borrowing.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "给定 5 个 borrow-checker 报错片段，逐个改对并解释报错", "assessable": true}
      ],
      "milestone": {"project": "写一个对 Vec<i32> 求和但不拿走所有权的函数", "competence_check": "能独立写出借用版函数且 caller 之后还能用这个 Vec"},
      "honest_limit": null
    },
    {
      "id": "compound-types",
      "title": "结构体、枚举与模式匹配",
      "dreyfus_stage": "novice",
      "prereqs": ["syntax-basics"],
      "objectives": [
        {"text": "定义 struct / enum，用 match 穷尽处理每个变体", "bloom": "apply"},
        {"text": "用 enum + match 建模一个状态机", "bloom": "create"}
      ],
      "resources": [
        {"title": "TRPL ch.6 Enums and Pattern Matching", "url": "https://doc.rust-lang.org/book/ch06-00-enums.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "做 Rustlings structs + enums；用 enum 写一个交通灯状态机，match 返回下一个状态", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "collections-strings",
      "title": "集合与字符串：Vec / HashMap / String vs &str",
      "dreyfus_stage": "advanced_beginner",
      "prereqs": ["compound-types", "borrowing-references"],
      "objectives": [
        {"text": "讲清 String（拥有）vs &str（借用）的区别和何时用哪个", "bloom": "understand"},
        {"text": "用 Vec + HashMap 解决一个统计类问题", "bloom": "apply"}
      ],
      "resources": [
        {"title": "TRPL ch.8 Common Collections", "url": "https://doc.rust-lang.org/book/ch08-00-common-collections.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "project", "prompt": "读一段文本，用 HashMap 统计词频，按出现次数排序打印 top 10", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "error-handling",
      "title": "错误处理：Result / Option / ?",
      "dreyfus_stage": "advanced_beginner",
      "prereqs": ["compound-types"],
      "objectives": [
        {"text": "区分可恢复（Result）与不可恢复（panic!）错误", "bloom": "understand"},
        {"text": "用 ? 传播错误，避免到处 unwrap", "bloom": "apply"}
      ],
      "resources": [
        {"title": "TRPL ch.9 Error Handling", "url": "https://doc.rust-lang.org/book/ch09-00-error-handling.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "把一个满是 .unwrap() 的读文件函数改写成返回 Result<_, io::Error> 并用 ? 传播", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "modules-crates",
      "title": "模块系统与 crate 依赖",
      "dreyfus_stage": "advanced_beginner",
      "prereqs": ["syntax-basics"],
      "objectives": [
        {"text": "用 mod / pub / use 组织代码", "bloom": "apply"},
        {"text": "从 crates.io 加一个依赖并在项目里用起来", "bloom": "apply"}
      ],
      "resources": [
        {"title": "TRPL ch.7 Managing Growing Projects", "url": "https://doc.rust-lang.org/book/ch07-00-managing-growing-projects-with-packages-crates-and-modules.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "把单文件程序拆成 2-3 个模块；加 `anyhow` 依赖并用它简化错误处理", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "generics-traits",
      "title": "泛型与 trait",
      "dreyfus_stage": "advanced_beginner",
      "prereqs": ["compound-types", "error-handling"],
      "objectives": [
        {"text": "写泛型函数 + trait bound", "bloom": "apply"},
        {"text": "为自己的类型实现标准 trait（如 Display / From）", "bloom": "apply"}
      ],
      "resources": [
        {"title": "TRPL ch.10.1-10.2 Generics & Traits", "url": "https://doc.rust-lang.org/book/ch10-00-generics.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "做 Rustlings generics + traits；给一个 Temperature 类型实现 Display 和 From<f64>", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "lifetimes",
      "title": "生命周期标注",
      "dreyfus_stage": "advanced_beginner",
      "prereqs": ["borrowing-references", "generics-traits"],
      "objectives": [
        {"text": "读懂 'a 标注表达的是引用有效期关系", "bloom": "understand"},
        {"text": "给一个返回引用的函数加正确的生命周期标注", "bloom": "apply"}
      ],
      "resources": [
        {"title": "TRPL ch.10.3 Validating References with Lifetimes", "url": "https://doc.rust-lang.org/book/ch10-03-lifetime-syntax.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "做 Rustlings lifetimes 全组；写一个返回两个 &str 中较长者的函数", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "closures-iterators",
      "title": "闭包与迭代器",
      "dreyfus_stage": "competent",
      "prereqs": ["generics-traits", "collections-strings"],
      "objectives": [
        {"text": "用 map / filter / collect / fold 替代手写 for 循环", "bloom": "apply"},
        {"text": "判断何时迭代器链比命令式循环更清晰/更慢", "bloom": "evaluate"}
      ],
      "resources": [
        {"title": "TRPL ch.13 Functional Language Features", "url": "https://doc.rust-lang.org/book/ch13-00-functional-features.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "把之前词频统计的循环版重写成迭代器链版，行为不变", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "smart-pointers",
      "title": "智能指针与内部可变性：Box / Rc / RefCell",
      "dreyfus_stage": "competent",
      "prereqs": ["lifetimes", "error-handling"],
      "objectives": [
        {"text": "解释 Box / Rc / RefCell 各自解决什么问题", "bloom": "understand"},
        {"text": "用 Rc<RefCell<T>> 实现一个共享可变的图/树节点", "bloom": "create"}
      ],
      "resources": [
        {"title": "TRPL ch.15 Smart Pointers", "url": "https://doc.rust-lang.org/book/ch15-00-smart-pointers.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "project", "prompt": "用 Box 实现一个递归链表；用 Rc<RefCell<>> 实现两个节点能互相引用的小图", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "testing-tooling",
      "title": "测试与工程化工具：test / clippy / rustfmt",
      "dreyfus_stage": "competent",
      "prereqs": ["modules-crates", "error-handling"],
      "objectives": [
        {"text": "写单元测试 + 集成测试，cargo test 跑通", "bloom": "apply"},
        {"text": "用 clippy + rustfmt 让代码符合社区规范", "bloom": "apply"}
      ],
      "resources": [
        {"title": "TRPL ch.11 Writing Automated Tests", "url": "https://doc.rust-lang.org/book/ch11-00-testing.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "给词频统计模块写 3 个单元测试 + 1 个集成测试；跑 cargo clippy 清掉所有 warning", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "concurrency",
      "title": "并发：线程、channel、Arc/Mutex",
      "dreyfus_stage": "competent",
      "prereqs": ["smart-pointers", "closures-iterators"],
      "objectives": [
        {"text": "用 thread::spawn + channel 在线程间传消息", "bloom": "apply"},
        {"text": "解释 Send/Sync 与 Arc<Mutex<T>> 为何能安全共享状态", "bloom": "analyze"}
      ],
      "resources": [
        {"title": "TRPL ch.16 Fearless Concurrency", "url": "https://doc.rust-lang.org/book/ch16-00-concurrency.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "drill", "prompt": "起 4 个线程并行算一个大 Vec 的和，用 Arc<Mutex<>> 或 channel 汇总，结果与单线程一致", "assessable": true}
      ],
      "milestone": null,
      "honest_limit": null
    },
    {
      "id": "capstone-cli",
      "title": "毕业项目：完整 CLI 工具",
      "dreyfus_stage": "competent",
      "prereqs": ["testing-tooling", "concurrency", "closures-iterators"],
      "objectives": [
        {"text": "把所有权/错误处理/模块/测试整合进一个真实可用的 CLI", "bloom": "create"}
      ],
      "resources": [
        {"title": "TRPL ch.12 An I/O Project: minigrep", "url": "https://doc.rust-lang.org/book/ch12-00-an-io-project.html", "type": "primary"}
      ],
      "exercises": [
        {"kind": "project", "prompt": "做一个 grep 克隆：读文件、按参数过滤行、错误用 Result 处理、带 clap 解析参数、写测试，发布到本地 cargo install", "assessable": true}
      ],
      "milestone": {"project": "一个能 cargo install 的 grep-clone CLI（参数解析 + 文件 IO + 错误处理 + 测试）", "competence_check": "能独立从零搭一个带测试和错误处理的 Rust CLI 并解释每个 unwrap/?/借用的选择"},
      "honest_limit": null
    }
  ]
}
